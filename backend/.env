# PostgreSQL Database (for Railway deployment)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/p2p_crypto

# SQLite Database (for local testing)
DATABASE_URL=sqlite:///./p2p_crypto.db

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email (Resend)
RESEND_API_KEY=
SENDER_EMAIL=onboarding@resend.dev

# CORS
CORS_ORIGINS=*

# Frontend URL
FRONTEND_URL=http://localhost:3000